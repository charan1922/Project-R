import os
import shutil
import re
import subprocess
from datetime import datetime
from tqdm import tqdm
import easyocr

# --- CONFIGURATION: MARCH BATCH PROCESSING ---
# Where the videos are coming from
VIDEO_DIR = "/content/drive/MyDrive/Trade_Finder_Videos/2026/March"

# Where the temporary images will live during processing
TEMP_FRAMES_DIR = "/content/test_frames"

# NEW BASE DESTINATION: TradeFinderOCR
BASE_OUTPUT_DIR = "/content/drive/MyDrive/TradeFinderOCR"

# Initialize OCR once (using GPU for speed)
reader = easyocr.Reader(['en'], gpu=True)

# Find all MP4 files in the March folder
video_files = sorted([f for f in os.listdir(VIDEO_DIR) if f.endswith('.mp4')])
print(f"📂 Found {len(video_files)} videos in {VIDEO_DIR} to process.")

total_saved_frames = 0

# Loop through each video one by one
for video_name in video_files:
    video_path = os.path.join(VIDEO_DIR, video_name)
    print(f"\n🎬 Starting Video: {video_name}")
    
    # 1. Clear out temp frames from the previous video
    shutil.rmtree(TEMP_FRAMES_DIR, ignore_errors=True)
    os.makedirs(TEMP_FRAMES_DIR, exist_ok=True)
    
    # 2. Extract Frames
    print("   -> Extracting frames (1 frame every 0.75s)...")
    subprocess.run([
        'ffmpeg', '-i', video_path, 
        '-vf', 'fps=1.333', 
        '-q:v', '2', 
        f'{TEMP_FRAMES_DIR}/frame_%04d.jpg'
    ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    extracted_frames = sorted([os.path.join(TEMP_FRAMES_DIR, f) for f in os.listdir(TEMP_FRAMES_DIR)])
    print(f"   -> 🚀 Running OCR on {len(extracted_frames)} frames...")
    
    # --- FOLDER ORGANIZATION LOGIC (Year -> Month -> Day) ---
    date_match = re.search(r'(\d{4}-\d{2}-\d{2})', video_name)
    trade_date = date_match.group(1) if date_match else "2026-01-01"

    dt_obj = datetime.strptime(trade_date, '%Y-%m-%d')
    year_folder = dt_obj.strftime('%Y')        # "2026"
    month_folder = dt_obj.strftime('%B')       # "March"
    day_folder = dt_obj.strftime('%d-%m-%Y')   # "04-03-2026"

    # Destination: /TradeFinderOCR/2026/March/04-03-2026/
    dest_path = os.path.join(BASE_OUTPUT_DIR, year_folder, month_folder, day_folder)
    os.makedirs(dest_path, exist_ok=True)

    saved_this_video = 0

    # 3. Scan and Filter
    for path in tqdm(extracted_frames, desc=f"Scanning {trade_date}", leave=False):
        try:
            results = reader.readtext(path, detail=0)
            text = " ".join(results).lower()

            # Filter keywords
            keywords = ["qty", "profit", "capital", "p&l", "position", "mtm"]
            if not any(word in text for word in keywords):
                continue

            # Save valid frames to the specific day folder
            new_img_name = f"{trade_date}_{os.path.basename(path)}"
            shutil.copy(path, os.path.join(dest_path, new_img_name))
            saved_this_video += 1
            total_saved_frames += 1
            
        except Exception as e:
            continue
            
    print(f"   -> ✅ Saved {saved_this_video} valid trade frames for {trade_date}.")

print(f"\n🎉 ALL BATCH PROCESSING COMPLETE!")
print(f"📂 Total filtered images saved across all videos: {total_saved_frames}")
print(f"Check your Drive folder: {BASE_OUTPUT_DIR}/{year_folder}/{month_folder}")
{
    "name": "@dhan/ts-sdk",
    "version": "1.0.0",
    "description": "Production-grade TypeScript SDK for the DhanHQ trading API (v2)",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "keywords": [
        "dhan",
        "trading",
        "stock",
        "nse",
        "bse",
        "sdk",
        "typescript"
    ],
    "license": "MIT",
    "dependencies": {
        "axios": "^1.6.0",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/ws": "^8.5.10",
        "typescript": "^5.7.0",
        "vitest": "^1.6.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
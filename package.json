{
  "name": "project-r",
  "version": "2.0.0",
  "description": "Project-R — Dhan V2 algorithmic trading platform with Historify historical data management",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "extract": "pnpm ts-node --project src/tsconfig.json src/extract.ts",
    "extract:v2": "pnpm ts-node --project src/tsconfig.json src/extract_v2.ts",
    "mcp": "pnpm ts-node --project src/tsconfig.json src/mcp-server.ts",
    "dev": "next dev -p 5000",
    "build": "next build --webpack",
    "start": "next start -p 5000",
    "serve": "pnpm serve dist -p 5000",
    "lint": "biome check .",
    "format": "biome format --write .",
    "install:browsers": "pnpm exec playwright install chromium",
    "clean": "rm -rf node_modules dist .next pnpm-lock.yaml",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts",
    "db:generate": "prisma generate --config prisma/prisma.config.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.4.4-r.3",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.58.2",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@sentry/nextjs": "^10.43.0",
    "@vercel/analytics": "^2.0.1",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.564.0",
    "mathjs": "^15.1.1",
    "next": "16.1.6",
    "next-safe-action": "^8.1.8",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "node-schedule": "^2.1.1",
    "nuqs": "^2.8.9",
    "otpauth": "^9.5.0",
    "playwright": "^1.58.2",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "stock-nse-india": "^1.3.0",
    "tailwind-merge": "^3.4.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "@sentry/cli"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/node-schedule": "^2.1.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "serve": "^14.2.5",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
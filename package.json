{
  "name": "project-r",
  "version": "2.0.0",
  "description": "Project-R — Dhan V2 algorithmic trading platform with Historify historical data management",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "extract": "pnpm ts-node --project src/tsconfig.json src/extract.ts",
    "extract:v2": "pnpm ts-node --project src/tsconfig.json src/extract_v2.ts",
    "mcp": "pnpm ts-node --project src/tsconfig.json src/mcp-server.ts",
    "dev": "next dev -p 5000",
    "build": "next build --webpack",
    "start": "next start -p 5000",
    "serve": "pnpm serve dist -p 5000",
    "lint": "eslint",
    "install:browsers": "pnpm exec playwright install chromium",
    "clean": "rm -rf node_modules dist .next pnpm-lock.yaml"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@duckdb/node-api": "1.4.4-r.3",

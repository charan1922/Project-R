    "@playwright/test": "^1.58.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.103",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.564.0",
    "mathjs": "^15.1.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "node-schedule": "^2.1.1",
    "playwright": "^1.58.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "stock-nse-india": "^1.3.0",

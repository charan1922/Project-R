generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Watchlist {
  id         Int      @id @default(autoincrement())
  symbol     String
  exchange   String   @default("NSE")
  segment    String   @default("EQ")
  securityId String?
  addedAt    DateTime @default(now())

  @@unique([symbol, exchange])
  @@map("watchlist")
}

model Activity {
  id        Int      @id @default(autoincrement())
  symbol    String
  exchange  String
  interval  String
  action    String
  rowsCount Int      @default(0)
  status    String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([symbol])
  @@map("activity")
}

model MasterContract {
  id         Int       @id @default(autoincrement())
  securityId String
  symbol     String
  exchange   String
  segment    String
  instrument String
  name       String    @default("")
  underlying String?
  expiryDate DateTime?
  syncDate   String

  @@unique([securityId, segment])
  @@index([exchange, symbol])
  @@index([segment, instrument, underlying])
  @@index([syncDate])
  @@map("master_contracts")
}

model BhavcopyDay {
  id          Int    @id @default(autoincrement())
  date        String
  symbol      String
  eqVolume    Float  @default(0)
  eqTurnover  Float  @default(0)
  eqHigh      Float  @default(0)
  eqLow       Float  @default(0)
  eqClose     Float  @default(0)
  futVolume   Float  @default(0)
  futOi       Float  @default(0)
  futOiChange Float  @default(0)
  futTurnover Float  @default(0)
  optVolume   Float  @default(0)
  optOi       Float  @default(0)
  optTurnover Float  @default(0)
  ceVolume    Float  @default(0)
  peVolume    Float  @default(0)

  @@unique([date, symbol])
  @@index([symbol])
  @@index([date])
  @@map("bhavcopy_days")
}

model Settings {
  id              Int     @id @default(1)
  dhanClientId    String  @default("")
  dhanAccessToken String  @default("")
  batchSize       Int     @default(10)
  rateLimitMs     Int     @default(250)
  defaultRange    String  @default("30")
  theme           String  @default("dark")
  chartHeight     Int     @default(450)
  autoRefresh     Boolean @default(true)
  showTooltips    Boolean @default(true)

  @@map("settings")
}
